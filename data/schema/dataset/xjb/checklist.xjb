<?xml version="1.0" encoding="UTF-8"?>
<jaxb:bindings version="1.0"
    xmlns:jaxb="http://java.sun.com/xml/ns/jaxb"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:namespace="http://jaxb2-commons.dev.java.net/namespace-prefix"
    xsi:schemaLocation="http://java.sun.com/xml/ns/jaxb http://java.sun.com/xml/ns/jaxb/bindingschema_2_0.xsd
    http://jaxb2-commons.dev.java.net/namespace-prefix https://raw.githubusercontent.com/Siggen/jaxb2-namespace-prefix/master/src/main/resources/prefix-namespace-schema.xsd">

	<jaxb:bindings schemaLocation="../xsd/checklist.xsd">
		<jaxb:schemaBindings>
			<jaxb:package name="cn.eaipchina.dataset"/>
		</jaxb:schemaBindings>
		 <jaxb:bindings >
		    <namespace:prefix name="aisc-cl" namespaceURI="https://www.eaipchina.cn/schema/dataset/checklist" />
            <namespace:prefix name="aisc-ds" namespaceURI="https://www.eaipchina.cn/schema/dataset/meta" />
		    <namespace:prefix name="aisc-cs" namespaceURI="https://www.eaipchina.cn/schema/dataset/checksum" />
        </jaxb:bindings>
	</jaxb:bindings>
	<jaxb:bindings schemaLocation="../xsd/checksum.xsd">
        <jaxb:schemaBindings>
            <jaxb:package name="cn.eaipchina.dataset"/>
        </jaxb:schemaBindings>
    </jaxb:bindings>
    <jaxb:bindings schemaLocation="../xsd/meta.xsd">
        <jaxb:schemaBindings>
            <jaxb:package name="cn.eaipchina.dataset"/>
        </jaxb:schemaBindings>
    </jaxb:bindings>
</jaxb:bindings>

